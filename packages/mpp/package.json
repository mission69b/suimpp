{
  "name": "@suimpp/mpp",
  "version": "0.8.0",
  "description": "Sui USDC payment method for the Machine Payments Protocol (MPP)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./x402": {
      "types": "./dist/x402.d.ts",
      "import": "./dist/x402.js",
      "require": "./dist/x402.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "keywords": [
    "mpp",
    "sui",
    "payment",
    "usdc",
    "ai",
    "agent",
    "402",
    "machine-payments",
    "suimpp"
  ],
  "author": "suimpp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mission69b/suimpp.git",
    "directory": "packages/mpp"
  },
  "homepage": "https://suimpp.dev",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "mppx": "^0.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20",
    "testcontainers": "^12.0.0",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  },
  "license": "MIT"
}
